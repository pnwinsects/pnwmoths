---
layout: base.njk
title: "Glossary -- PNW Moths"
permalink: /glossary/index.html
---
<h1>Glossary</h1>

<style>
figure {
  float: right;
  margin-left: 1rem;
  margin-bottom: 1rem;
}
dt {
  clear: both;
  font-weight: bold;
}
section {
  clear: both;
  margin-top: 1rem;
}
</style>

<nav aria-label="Alphabetic index">
  <ul>
    {% for letter, terms in glossary %}
      <li><a href="#letter-{{ letter }}">{{ letter }}</a></li>
    {% endfor %}
  </ul>
</nav>

{% for letter, terms in glossary %}
  <section id="letter-{{ letter }}">
    <h2>{{ letter }}</h2>
    <dl>
      {% for term in terms %}
        <dt id="term-{{ term.slug }}">{{ term.term }}</dt>
        <dd>
          {% if term.image_filename %}
            <figure>
              <img src="{{ ('/images/glossary/' + term.image_filename) | url }}"
                   alt="{{ term.term }}"
                   width="188" height="225">
              {% if term.photographer %}
                <figcaption>{{ term.photographer }}</figcaption>
              {% endif %}
            </figure>
          {% endif %}
          {{ term.definition }}
        </dd>
      {% endfor %}
    </dl>
  </section>
{% endfor %}
