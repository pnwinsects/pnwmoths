---
layout: base.njk
pagination:
  data: species
  size: 1
  alias: sp
permalink: "species/{{ sp.slug }}/index.html"
eleventyComputed:
  title: "{{ sp.genus }} {{ sp.species }} — PNW Moths"
---

<nav class="species-breadcrumb" aria-label="Taxonomy">
  <a href="{{ '/browse/' | url }}">{{ sp.family }}</a>
  {% if sp.subfamily %}
  <span aria-hidden="true"> › </span>
  <a href="{{ '/browse/' | url }}">{{ sp.subfamily }}</a>
  {% endif %}
  <span aria-hidden="true"> › </span>
  <span>{{ sp.genus }}</span>
</nav>

<div class="species-header">
  <div class="species-title">
    <h1><em>{{ sp.genus }} {{ sp.species }}</em>{% if sp.authority %} {{ sp.authority }}{% endif %}</h1>
    {% if sp.common_name %}<div class="species-common-name">{{ sp.common_name }}</div>{% endif %}
  </div>
  {% if sp.noc_id %}
  <div class="species-noc">
    <span class="species-noc-id">{{ sp.noc_id }}</span>
  </div>
  {% endif %}
</div>

<div class="species-content">
  <div class="species-photos">
    {% set spImages = images[sp.slug] %}
    {% set highResEntry = speciesPhotos[sp.slug] %}
    <pnwm-image-slideshow
      slug="{{ sp.slug }}"
      {% if highResEntry and highResEntry.high_res_available %}
      high-res-available
      high-res-specimens="{{ highResEntry.specimens | tojson | escape }}"
      cdn-base-url="{{ cdnBaseUrl }}"
      prefix-url="{{ '/osd-images/' | url }}"
      {% endif %}
      data-pagefind-ignore>
      {% if (not (highResEntry and highResEntry.high_res_available)) and spImages and spImages.length > 0 %}
        {% for img in spImages %}
          <figure>
            <img src="{{ cdnBaseUrl }}/{{ sp.slug }}/{{ img.filename | urlencode }}"
                 alt="{{ sp.genus }} {{ sp.species }}"
                 data-photographer="{{ img.photographer }}"
                 {% if img.locality %}data-locality="{{ img.locality }}"{% endif %}
                 {% if img.state %}data-state="{{ img.state }}"{% endif %}
                 {% if img.elevation_ft %}data-elevation="{{ img.elevation_ft }}"{% endif %}
                 {% if img.year %}data-year="{{ img.year }}"{% endif %}
                 {% if img.month %}data-month="{{ img.month }}"{% endif %}
                 {% if img.day %}data-day="{{ img.day }}"{% endif %}
                 {% if img.collector %}data-collector="{{ img.collector }}"{% endif %}
                 {% if img.subspecies %}data-subspecies="{{ img.subspecies }}"{% endif %}>
            <figcaption>{{ img.photographer }}</figcaption>
          </figure>
        {% endfor %}
      {% elif highResEntry and highResEntry.high_res_available %}
        {% for specimen in highResEntry.specimens %}
          <figure>
            <img src="{{ cdnBaseUrl }}/{{ specimen.tiles_path }}/{{ specimen.specimen_id }}-{{ specimen.view }}_files/8/0_0.webp"
                 alt="{{ sp.genus }} {{ sp.species }}"
                 onerror="this.style.background='#ddd'">
            <figcaption>Specimen {{ specimen.specimen_id }} · {{ "Dorsal" if specimen.view == "D" else "Ventral" }}</figcaption>
          </figure>
        {% endfor %}
      {% else %}
        <figure>
          <div aria-label="No images available for this species">
            No photos on file for this species.
          </div>
        </figure>
      {% endif %}
    </pnwm-image-slideshow>

    {% if sp.similar_slugs and sp.similar_slugs.length > 0 %}
      <section class="similar-species">
        <h2>Similar species</h2>
        <div class="similar-species-row">
          {% for slug in sp.similar_slugs %}
            {% for s in species %}
              {% if s.slug == slug %}
                {% set simImages = images[slug] %}
                <a class="similar-species-entry" href="{{ ('/species/' + slug + '/') | url }}">
                  <div class="similar-species-thumb">
                    {% if simImages and simImages.length > 0 %}
                      <img src="{{ cdnBaseUrl }}/{{ slug }}/{{ simImages[0].filename | urlencode }}"
                           alt="{{ s.genus }} {{ s.species }}"
                           height="93"
                           loading="lazy">
                    {% else %}
                      <div class="similar-species-placeholder" aria-hidden="true"></div>
                    {% endif %}
                  </div>
                  <span class="similar-species-name"><em>{{ s.genus }} {{ s.species }}</em></span>
                </a>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </div>

  <div class="species-data">
    <pnwm-occurrence-map slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-occurrence-map>
    <pnwm-phenology-chart slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-phenology-chart>
    {# Filter bar drives map and chart via pnwm-filter-change events (see script below) #}
    <pnwm-filter-bar slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-filter-bar>
    <noscript data-pagefind-ignore>
      <p>Enable JavaScript to view the interactive map and filters. Occurrence data requires JavaScript.</p>
    </noscript>
  </div>
</div>

{% set prosePath = "src/content/species/" + sp.slug + ".md" %}
{% if prosePath | fileExists %}
  <div class="species-prose">
    {% renderFile prosePath %}
  </div>
{% endif %}

<script type="module">
  const map = document.querySelector('pnwm-occurrence-map');
  const chart = document.querySelector('pnwm-phenology-chart');

  document.addEventListener('pnwm-filter-change', (e) => {
    if (map) map.filters = e.detail;
    if (chart) chart.filters = e.detail;
  });
</script>
