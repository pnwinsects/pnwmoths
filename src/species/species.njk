---
layout: base.njk
pagination:
  data: species
  size: 1
  alias: sp
permalink: "species/{{ sp.slug }}/index.html"
eleventyComputed:
  title: "{{ sp.genus }} {{ sp.species }} — PNW Moths"
---
<h1><em>{{ sp.genus }} {{ sp.species }}</em></h1>

<dl>
  <dt>Common name</dt><dd>{{ sp.common_name }}</dd>
  <dt>NOC ID</dt><dd>{{ sp.noc_id }}</dd>
  <dt>Authority</dt><dd>{{ sp.authority }}</dd>
  <dt>Family</dt><dd>{{ sp.family }}</dd>
</dl>

{% set prosePath = "src/content/species/" + sp.slug + ".md" %}
{% if prosePath | fileExists %}
  {% renderFile prosePath %}
{% endif %}

{# Interactive occurrence data — requires JavaScript (see DATA-04 + INTV-05 reconciliation).
   Per DATA-04: occurrence rows are NOT embedded in HTML at build time.
   Per INTV-05: graceful degradation required.
   Resolution: noscript block explains occurrence data requires JS.
   Static photos, taxonomy, and prose remain visible without JS. #}

<section>
  <h2>Occurrence Data</h2>
  <pnwm-filter-bar slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-filter-bar>
  <pnwm-occurrence-map slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-occurrence-map>
  <pnwm-phenology-chart slug="{{ sp.slug }}" data-pagefind-ignore></pnwm-phenology-chart>
  <noscript data-pagefind-ignore>
    <p>Enable JavaScript to view the interactive map and filters. Occurrence data is available in the table below.</p>
  </noscript>
</section>

{% set spImages = images[sp.slug] %}
<section>
  <h2>Photos</h2>
  <pnwm-image-slideshow slug="{{ sp.slug }}" data-pagefind-ignore>
    {% if spImages and spImages.length > 0 %}
      {% for img in spImages %}
        <figure>
          <img src="{{ cdnBaseUrl }}/{{ sp.slug }}/{{ img.filename | urlencode }}"
               alt="{{ sp.genus }} {{ sp.species }}"
               data-photographer="{{ img.photographer }}">
          <figcaption>{{ img.photographer }}</figcaption>
        </figure>
      {% endfor %}
    {% else %}
      <figure>
        <div aria-label="No images available for this species">
          No photos on file for this species.
        </div>
      </figure>
    {% endif %}
  </pnwm-image-slideshow>
</section>

{% if sp.similar_slugs and sp.similar_slugs.length > 0 %}
  <section>
    <h2>Similar species</h2>
    <ul>
      {% for slug in sp.similar_slugs %}
        {% for s in species %}
          {% if s.slug == slug %}
            <li><a href="{{ ('/species/' + slug + '/') | url }}">{{ s.common_name or (s.genus + ' ' + s.species) }}</a></li>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </ul>
  </section>
{% endif %}

<script type="module">
  // Wire filter-bar events to map and chart components
  const map = document.querySelector('pnwm-occurrence-map');
  const chart = document.querySelector('pnwm-phenology-chart');

  document.addEventListener('pnwm-filter-change', (e) => {
    if (map) map.filters = e.detail;
    if (chart) chart.filters = e.detail;
  });
</script>
