{
  "name": "pnwmoths",
  "version": "1.0.0",
  "description": "PNW Moths static site — proof-of-concept reconstruction as a fully static site",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-data.js",
    "build:eleventy": "npx @11ty/eleventy",
    "build:copy-parquet": "node scripts/copy-parquet.js",
    "build:pagefind": "pagefind --site _site",
    "build:validate-links": "lychee --root-dir _site --offline '_site/**/*.html'",
    "build:check-weight": "node scripts/check-page-weight.js",
    "build": "npm run build:data && npm run build:eleventy && npm run build:copy-parquet && npm run build:pagefind && npm run build:validate-links && npm run build:check-weight",
    "test": "node --test scripts/build-data.test.js src/components/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@duckdb/node-api": "^1.5.1-r.2",
    "@picocss/pico": "^2.1.1",
    "chart.js": "^4.5.1",
    "csv-parse": "^6.2.1",
    "hyparquet": "^1.25.6",
    "leaflet": "^1.9.4",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@11ty/eleventy-plugin-vite": "^7.0.0",
    "pagefind": "^1.5.2",
    "vite": "^7.3.2"
  }
}
